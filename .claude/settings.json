{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_FEEDBACK_COMMAND": "1"
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)"
    ],
    "ask": [
      "mcp__claude_ai_Klaviyo__create_campaign",
      "mcp__claude_ai_Klaviyo__create_dnd_email_template",
      "mcp__claude_ai_Klaviyo__create_email_template",
      "mcp__claude_ai_Klaviyo__create_profile",
      "mcp__claude_ai_Klaviyo__create_translation",
      "mcp__claude_ai_Klaviyo__clone_email_template",
      "mcp__claude_ai_Klaviyo__delete_email_template",
      "mcp__claude_ai_Klaviyo__delete_translation",
      "mcp__claude_ai_Klaviyo__update_dnd_email_template",
      "mcp__claude_ai_Klaviyo__update_email_template",
      "mcp__claude_ai_Klaviyo__update_profile",
      "mcp__claude_ai_Klaviyo__update_translation",
      "mcp__claude_ai_Klaviyo__upload_image_from_url",
      "mcp__claude_ai_Klaviyo__assign_template_to_campaign_message",
      "mcp__claude_ai_Klaviyo__subscribe_profile_to_marketing",
      "mcp__claude_ai_Klaviyo__unsubscribe_profile_from_marketing"
    ]
  }
}
